@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-body">

            <h2 class="card-title mb-3">About This Project</h2>

            <p class="lead">
                This web application was developed by <strong>Andrii Shevchuk</strong>.
            </p>

            <hr />

            <h5>Project Description</h5>
            <p>
                The system allows users to upload a CSV file with employee data and manage it directly in the browser.
            </p>

            <h5>Features</h5>
            <ul>
                <li>Upload employee data from CSV file</li>
                <li>Inline editing of employee information</li>
                <li>Client-side validation</li>
                <li>Sorting by any column</li>
                <li>Search and filtering</li>
                <li>Delete employees</li>
            </ul>

            <h5>Technologies Used</h5>
            <ul>
                <li>ASP.NET Core MVC</li>
                <li>Entity Framework Core</li>
                <li>JavaScript (Fetch API)</li>
            </ul>

        </div>
    </div>

</div>
